# ── Filtro de sesiones ──────────────────────────────────────────────
# Fecha ISO desde la cual filtrar sesiones (tiene precedencia sobre SINCE_DAYS)
SINCE_DATE=
# Cantidad de días hacia atrás (default: 1)
SINCE_DAYS=1

# ── Slack ──────────────────────────────────────────────────────────
SLACK_ENABLED=true
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL_ID=C0123456789

# ── Email (via Mail.app / osascript) ──────────────────────────────
EMAIL_ENABLED=false
EMAIL_RECIPIENT=you@example.com

# ── Proyectos ─────────────────────────────────────────────────────
# Prefijo a remover de los nombres de proyectos (e.g. workspace-gitlab-myorg-)
PROJECT_STRIP_PREFIX=
# Solo mostrar proyectos que empiecen con este prefijo (vacío = todos)
PROJECT_INCLUDE_PREFIX=

# ── Backfill ──────────────────────────────────────────────────────
# Fecha desde la cual hacer backfill (default: 2026-04-01)
BACKFILL_SINCE_DATE=2026-04-01
